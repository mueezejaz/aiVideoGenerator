{
  "name": "aivideogenerator",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --watch src --ext js --exec \"electron .\"",
    "build:client": "cd src/client && npm run build",
    "build:electron": "electron-builder",
    "build": "npm run build:client && npm run build:electron"
  },
  "build": {
    "appId": "com.aivideogenerator.app",
    "productName": "AI Video Generator",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "src/app.js",
      "src/ipc/**/*",
      "src/preload/**/*",
      "src/services/**/*",
      "src/utils/**/*",
      "src/windows/**/*",
      "src/client/dist/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**",
      "node_modules/@ffprobe-installer/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^25.0.0",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.53",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "ai": "^6.0.138",
    "edge-tts-universal": "^1.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "zod": "^4.3.6"
  }
}